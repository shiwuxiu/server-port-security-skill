# 公网服务器端口安全维护 - 配置文件模板
# 复制此文件为 config.yaml 并填入实际值

# ============================================
# 告警通知配置
# ============================================
alert:
  # 钉钉/企业微信 Webhook URL（留空则不发送通知）
  # 钉钉格式: https://oapi.dingtalk.com/robot/send?access_token=xxx
  # 企业微信格式: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
  webhook_url: ""

  # 邮件通知（可选）
  smtp:
    host: ""
    port: 587
    user: ""
    password: ""
    recipients: []

# ============================================
# 白名单配置
# ============================================
whitelist:
  # 允许访问敏感端口的 IP 段
  # 格式: CIDR，支持多个
  allowed_ips:
    - "127.0.0.1/8"           # 本地回环
    - "10.0.0.0/8"            # 内网 A 类
    - "172.16.0.0/12"         # 内网 B 类
    - "192.168.0.0/16"        # 内网 C 类
    # - "100.x.x.x/32"        # Tailscale 虚拟 IP（示例）
    # - "你的本地公网IP/32"     # 办公网络

  # Cloudflare CDN IP 段（用于源站防护）
  # 如果使用 Cloudflare，防火墙 80/443 应只放行这些 IP
  cloudflare_ips:
    - "173.245.48.0/20"
    - "103.21.244.0/22"
    - "103.22.200.0/22"
    - "103.31.4.0/22"
    - "141.101.64.0/18"
    - "108.162.192.0/18"
    - "190.93.240.0/20"
    - "188.114.96.0/20"
    - "197.234.240.0/22"
    - "198.41.128.0/17"
    - "162.158.0.0/15"
    - "104.16.0.0/13"
    - "104.24.0.0/14"
    - "172.64.0.0/13"
    - "131.0.72.0/22"

# ============================================
# 扫描配置
# ============================================
scan:
  # 需要检查的敏感端口（留空使用默认列表）
  # 默认: 9200,9300,6379,6380,27017,2375,2376,2379,2380,19530,11211,8088
  sensitive_ports: []

  # 忽略检查的端口（特殊情况，如已知安全的公网服务）
  ignore_ports: []
  # 示例: - 8080  # 已知安全的 Web 服务

  # 忽略检查的服务名
  ignore_services: []

# ============================================
# 深度检查开关
# ============================================
deep_check:
  # SSH 安全配置检查
  ssh_hardening: true

  # 恶意定时任务检查
  cron_backdoor: true

  # 凭据泄露扫描
  credential_leak: true

  # 容器安全检查
  container_security: true

  # 源站 IP 暴露检查（重要！）
  source_ip_exposure: true

# ============================================
# 监控配置
# ============================================
monitor:
  # ES 索引名称
  es_index: "moredoc-v2"

  # 日志文件路径
  log_dir: "/www/backup/logs"

  # 文档数异常阈值（减少超过此百分比触发告警）
  doc_drop_threshold: 50

  # 勒索索引特征名（检测到立即告警）
  ransom_indices:
    - "read_me"
    - "contact_me"
    - "restore_me"
    - "backup_me"

# ============================================
# 备份配置
# ============================================
backup:
  # 备份目录
  dir: "/www/backup"

  # 保留天数
  retention_days: 7

  # 远程备份（可选）
  remote:
    enabled: false
    # rsync 目标
    # rsync_dest: "user@backup-server:/backup/moredoc"